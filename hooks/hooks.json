{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nolto flush --detach",
            "timeout": 10
          }
        ],
        "description": "Flush queued Nolto progress updates at session end (non-blocking; exits 0 even on failure)."
      }
    ]
  }
}
